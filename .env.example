# Copy to ~/.arrowcode/.env after `arrowcode --init` (or set in your shell).
# Never commit real keys.

# Global (NVIDIA NIM default)
NVIDIA_API_KEY=nvapi-your-key-here
ARROWCODE_PROVIDER=nim
ARROWCODE_MODEL=""
ARROWCODE_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional
# ARROWCODE_YOLO=0
# OPENAI_API_KEY=
# ARROW_FE_PROVIDER=openai
# ARROW_FE_API_KEY=
# ARROW_BE_PROVIDER=ollama
# ARROW_BE_BASE_URL=http://localhost:11434/v1
# ARROW_BE_MODEL=qwen2.5-coder:14b
